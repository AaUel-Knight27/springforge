'use client';

import { useState, useEffect } from 'react';
import { {{entityNameLower}}Api } from '../../lib/api/{{entityNameKebab}}';
import type { {{entityName}}Request } from '../../types/{{entityNameKebab}}';

interface Props {
  editId: number | null;
  onSuccess: () => void;
}

export default function {{entityName}}Form({ editId, onSuccess }: Props) {
  const [formData, setFormData] = useState<{{entityName}}Request>({
{{#fields}}
    {{name}}: {{#tsTypeIsNumber}}0{{/tsTypeIsNumber}}{{#tsTypeIsBoolean}}false{{/tsTypeIsBoolean}}{{#tsTypeIsString}}''{{/tsTypeIsString}},
{{/fields}}
  });
  const [loading, setLoading] = useState(false);

  useEffect(() => {
    if (editId) {
      {{entityNameLower}}Api.getById(editId).then((res) => setFormData(res.data));
    }
  }, [editId]);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    try {
      if (editId) {
        await {{entityNameLower}}Api.update(editId, formData);
      } else {
        await {{entityNameLower}}Api.create(formData);
      }
      onSuccess();
    } catch (err) {
      alert('Error saving record');
    } finally {
      setLoading(false);
    }
  };

  const inputStyle = {
    width: '100%',
    padding: '10px 14px',
    background: '#0f172a',
    border: '1px solid #334155',
    borderRadius: '8px',
    color: '#e2e8f0',
    fontSize: '14px',
    outline: 'none',
  };

  const labelStyle = {
    display: 'block',
    color: '#94a3b8',
    fontSize: '13px',
    fontWeight: '500' as const,
    marginBottom: '6px',
  };

  return (
    <form onSubmit={handleSubmit}>
      <div style={ { display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))', gap: '16px' } }>
{{#fields}}
        <div>
          <label style={labelStyle}>{{nameCapitalized}}</label>
          <input
            type="text"
            value={String(formData.{{name}} || '')}
            onChange={(e) => setFormData({ ...formData, {{name}}: e.target.value as any })}
            style={inputStyle}
            placeholder="Enter {{name}}"
          />
        </div>
{{/fields}}
      </div>

      <div style={ { marginTop: '20px', display: 'flex', gap: '12px' } }>
        <button
          type="submit"
          disabled={loading}
          style={ {
            padding: '10px 24px',
            background: '#3b82f6',
            color: '#fff',
            border: 'none',
            borderRadius: '8px',
            fontSize: '14px',
            fontWeight: '500',
            cursor: loading ? 'not-allowed' : 'pointer',
            opacity: loading ? 0.7 : 1,
          } }
        >
          {loading ? 'Saving...' : editId ? 'Update' : 'Create'}
        </button>
      </div>
    </form>
  );
}
