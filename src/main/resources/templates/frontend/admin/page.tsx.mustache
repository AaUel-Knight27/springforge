'use client';

export default function AdminDashboard() {
  const stats = [
{{#entities}}
    { name: '{{entityName}}', icon: '📋', color: '#3b82f6' },
{{/entities}}
  ];

  return (
    <div>
      <h1 style={ {
        fontSize: '28px',
        fontWeight: '700',
        color: '#f8fafc',
        marginBottom: '8px',
        fontFamily: "'Inter', sans-serif",
      } }>
        Dashboard
      </h1>
      <p style={ { color: '#94a3b8', marginBottom: '32px' } }>
        Welcome to the {{projectName}} admin panel
      </p>

      {/* Entity cards */}
      <div style={ {
        display: 'grid',
        gridTemplateColumns: 'repeat(auto-fill, minmax(240px, 1fr))',
        gap: '20px',
        marginBottom: '32px',
      } }>
        {stats.map((item) => (
          <div
            key={item.name}
            style={ {
              background: '#1e293b',
              borderRadius: '12px',
              padding: '24px',
              border: '1px solid #334155',
              transition: 'transform 0.15s, border-color 0.15s',
              cursor: 'pointer',
            } }
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'translateY(-2px)';
              e.currentTarget.style.borderColor = item.color;
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'translateY(0)';
              e.currentTarget.style.borderColor = '#334155';
            }}
          >
            <div style={ { fontSize: '32px', marginBottom: '12px' } }>{item.icon}</div>
            <h3 style={ { color: '#e2e8f0', fontSize: '16px', fontWeight: '600' } }>{item.name}</h3>
            <p style={ { color: '#64748b', fontSize: '13px', marginTop: '4px' } }>Manage records</p>
          </div>
        ))}
      </div>

      {/* Quick actions */}
      <div style={ {
        background: '#1e293b',
        borderRadius: '12px',
        padding: '24px',
        border: '1px solid #334155',
      } }>
        <h2 style={ { color: '#e2e8f0', fontSize: '18px', fontWeight: '600', marginBottom: '16px' } }>
          Quick Actions
        </h2>
        <div style={ { display: 'flex', gap: '12px', flexWrap: 'wrap' } }>
{{#entities}}
          <a
            href="/admin/{{entityNameKebab}}"
            style={ {
              padding: '8px 16px',
              background: '#334155',
              borderRadius: '8px',
              color: '#e2e8f0',
              fontSize: '13px',
              textDecoration: 'none',
              transition: 'background 0.15s',
            } }
            onMouseEnter={(e) => { e.currentTarget.style.background = '#475569'; }}
            onMouseLeave={(e) => { e.currentTarget.style.background = '#334155'; }}
          >
            Manage {{entityName}}
          </a>
{{/entities}}
        </div>
      </div>
    </div>
  );
}
